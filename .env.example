# Fulgoria — server fino. El documento se procesa 100% en el navegador y NUNCA llega acá.
# Copiá este archivo a .env y completá los valores. El .env NO va al repo.

PORT=3000

# --- Login ---
# AUTH_ENABLED=false → la app se sirve sin clave (uso local / red privada).
AUTH_ENABLED=true
AUTH_USER=diego

# Tu contraseña, en texto plano (como Escriba/Fisherboy).
# Opcional, más seguro si el .env se filtra: un hash bcrypt en vez del texto plano.
#   node server.js --hash 'tu-contraseña'   ← y pegás el $2a$... acá
AUTH_PASSWORD=

# Secreto para firmar la cookie de sesión. Generalo con:
#   openssl rand -hex 32
SESSION_SECRET=

# Duración de la sesión, en horas.
SESSION_TTL_HOURS=12

# Cookie Secure: true detrás de HTTPS (EasyPanel). Poné false solo para probar local por http://.
COOKIE_SECURE=true

# --- Identidad: login propio (default) o federado con Lockatus (el hub de la suite) ---
# AUTH_MODE=local (default) → usa el login de arriba (AUTH_USER/AUTH_PASSWORD). NADA cambia.
# AUTH_MODE=federado → el login lo maneja Lockatus (SSO + 2FA + roles desde la matriz). En ese
#   modo NO hace falta AUTH_USER/AUTH_PASSWORD; sí SESSION_SECRET y las 3 vars de abajo. Antes de
#   usarlo: registrá el redirect_uri (LOCKATUS_REDIRECT_URI) y dale rol a los usuarios en Lockatus.
AUTH_MODE=local
LOCKATUS_ISSUER=
# Slug de esta app en Lockatus (su catálogo de roles). Para Fulgoria: "fulgoria".
LOCKATUS_CLIENT_ID=fulgoria
# A dónde vuelve Lockatus tras el login. Debe coincidir EXACTO con lo registrado en el hub.
LOCKATUS_REDIRECT_URI=

# --- Ecosistema (opcional) ---
# Destino del botón "Enviar a Escriba". Vacío → "/" (la propia app). Poné la URL de tu Escriba,
# ej. https://tu-escriba.com/  o un path interno si están en el mismo dominio (ej. /escriba).
ESCRIBA_URL=
